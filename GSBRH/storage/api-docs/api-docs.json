    "paths": {
        "/auth/login": {
            "post": {
                "tags": [
                    "Authentification"
                ],
                "summary": "Connexion utilisateur",
                "operationId": "8cb7742ae98d0990acb2907c4e00bf24",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "identifiant",
                                    "mdp"
                                ],
                                "properties": {
                                    "identifiant": {
                                        "type": "string",
                                        "example": "user123"
                                    },
                                    "mdp": {
                                        "type": "string",
                                        "example": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Connexion réussie"
                    },
                    "401": {
                        "description": "Identifiants incorrects"
                    },
                    "500": {
                        "description": "Erreur serveur"
                    }
                }
            }
        },
        "/auth/register": {
            "post": {
                "tags": [
                    "Authentification"
                ],
                "summary": "Inscription utilisateur",
                "operationId": "ed42f392010c301892e640067141676e",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "identifiant",
                                    "mdp",
                                    "id_praticiens"
                                ],
                                "properties": {
                                    "identifiant": {
                                        "type": "string",
                                        "example": "newuser"
                                    },
                                    "mdp": {
                                        "type": "string",
                                        "example": "password123"
                                    },
                                    "id_praticiens": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "privilèges": {
                                        "type": "integer",
                                        "example": 0
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Utilisateur créé"
                    },
                    "422": {
                        "description": "Erreur de validation"
                    }
                }
            }
        },
        "/auth/logout": {
            "post": {
                "tags": [
                    "Authentification"
                ],
